# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
# 本番: https://tom-survey-app.vercel.app
# テスト: https://survey-app-git-develop-tom-5990s-projects.vercel.app
# ローカル: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase SMTP (Resend APIキー) — Supabaseダッシュボードで設定
# Authentication > Email > SMTP Settings > Password
# SUPABASE_AUTH_SMTP_PASS=re_xxxx  ← コードには含めない。パスワードマネージャーで管理。
